# Copy to .env for local development.
# SQLite database file, resolved relative to apps/api/ — keep it in sync with the
# app/seed/migration default (prisma/dev.db) so the CLI and the app use one DB.
DATABASE_URL="file:./prisma/dev.db"

# Port the API server listens on.
PORT=3000

# Secret used to sign session JWTs. Set a strong value in any real deployment
# (Phase 8 hardening will fail fast if it's missing in production).
JWT_SECRET="dev-insecure-secret-change-me"

# Credentials for the single seeded HR-Manager account (used by `pnpm --filter api seed`).
AUTH_EMAIL="hr@acme.example"
AUTH_PASSWORD="change-me-please"
